DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Caminho do banco SQLite. Aponte para FORA de pastas sincronizadas
# (OneDrive/Dropbox/etc.) — o banco guarda tokens e corpos de e-mail.
# Ex.: C:\dev\gerenciador\db.sqlite3
DJANGO_DB_PATH=

# Chave de criptografia dos tokens OAuth em repouso (obrigatoria em producao).
# Gere com:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DJANGO_FIELD_ENCRYPTION_KEY=

# Google OAuth (login social + futura autorizacao do Gmail).
# Gere as credenciais no Google Cloud Console. Enquanto vazias, o login
# tradicional por e-mail/senha funciona normalmente.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
